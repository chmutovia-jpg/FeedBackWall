# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings -> API in the Supabase dashboard).
#
# If these are left unset, FeedbackWall runs in local demo mode: all data
# stays in this browser's localStorage and nothing is shared between users.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
